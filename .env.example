# ScoutPass does not require cloud-AI credentials.
# Runtime paths may be overridden locally; never put wallet secrets here.
SCOUTPASS_DATA_DIR=.scoutpass/data
SCOUTPASS_ROLE=player
QVAC_CONFIG_PATH=qvac.config.json

# Public testnet configuration only. The default is Ethereum Sepolia.
SCOUTPASS_WALLET_NETWORK=ethereum-sepolia
SCOUTPASS_TEST_USDT_ADDRESS=0xd077a400968890eacc75cdc901f0356c943e4fdb
