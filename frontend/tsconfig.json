{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@scoutpass/backend/contracts": ["../backend/src/contracts/index.ts"],
      "@scoutpass/backend/runtime": ["../backend/src/runtime/index.ts"],
      "@scoutpass/backend/sharing": ["../backend/src/sharing.ts"]
    },
    "types": ["vite/client", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx", "vite.config.ts"]
}
